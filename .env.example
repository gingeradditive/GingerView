# Klipper/Moonraker Configuration
# Copy this file to .env and update with your actual settings

# Moonraker server IP and port
VITE_MOONRAKER_HOST=192.168.1.163
VITE_MOONRAKER_PORT=7125

# Optional: WebSocket URL (will be constructed from host/port if not provided)
# VITE_MOONRAKER_WS_URL=ws://192.168.1.163:7125/websocket

# Optional: HTTP API URL (will be constructed from host/port if not provided)
# VITE_MOONRAKER_API_URL=http://192.168.1.163:7125

# Optional: Printer name for display
VITE_PRINTER_NAME=Klipper Printer

# Optional: Connection timeout in milliseconds
VITE_CONNECTION_TIMEOUT=5000

# Network API Configuration
# If your Wi-Fi/network service runs elsewhere, set these values.
# By default host follows VITE_MOONRAKER_HOST and port defaults to 8000.
VITE_NETWORK_API_HOST=192.168.1.163
VITE_NETWORK_API_PORT=8000

# Optional: set full base URL directly (overrides host/port)
# VITE_NETWORK_API_BASE_URL=http://192.168.1.163:8000
